            "dst": "gu:/Pictures/",
            "log": "C:/Users/nahid/script_output/rclone/Pictures_check.log",
            "label": "\uf03e",
            "left_click_cmd": "rclone sync src dst -P --fast-list --track-renames --exclude \".globalTrash/**\" --exclude \".stfolder/**\" --log-level INFO",
